# Copy this file to ".env" and fill in your key, OR export the variable in your shell.
# The .env file is git-ignored — never commit real keys.
#
# Only needed for the AI commentary component (Task 4, src/ai_commentary.py).
# Without it, that component logs a "no_api_key" failure mode and uses a
# deterministic offline fallback, so the rest of the pipeline still runs.

ANTHROPIC_API_KEY=

# Optional: override the model (defaults to a fast, cheap Claude model).
# AI_MODEL=claude-haiku-4-5-20251001
